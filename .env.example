# Lexienn environment variables — copy to .env.local for local dev.
# For production, set these in Vercel Project Settings → Environment Variables.
# Never commit .env.local or real API keys to git.
# Never use NEXT_PUBLIC_ prefix for secret keys.

# --- AI dictionary / translation (server-only) ---
AI_ENABLED=true
AI_PROVIDER=openai
# Optional: not used by default OpenAI client; reserved for custom base URLs
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_FALLBACK_ENABLED=true
AI_TIMEOUT_MS=20000

# --- Production UI flags (browser-safe) ---
# When false (default), Developer Mode toggle and diagnostics are hidden.
NEXT_PUBLIC_ENABLE_DEVELOPER_MODE=false

# --- AI-generated voice (server-only; uses AI_API_KEY) ---
VOICE_ENABLED=true
VOICE_PROVIDER=openai
VOICE_MODEL=gpt-4o-mini-tts
VOICE_NAME=alloy
VOICE_FALLBACK_ENABLED=true
VOICE_TIMEOUT_MS=20000

# --- Speech-to-text input (server-only; uses AI_API_KEY) ---
# Browser speech recognition is tried first when supported.
SPEECH_INPUT_ENABLED=true
SPEECH_INPUT_PROVIDER=openai
SPEECH_INPUT_MODEL=whisper-1
SPEECH_INPUT_FALLBACK_ENABLED=true
SPEECH_INPUT_TIMEOUT_MS=20000
